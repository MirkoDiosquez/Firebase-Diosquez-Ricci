rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────────

    function getRol() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol;
    }

    function esAdmin() {
      return getRol() == 'admin';
    }

    function esVendedor() {
      return getRol() == 'vendedor';
    }

    function esComprador() {
      return getRol() == 'comprador';
    }

    // ─── Colección: usuarios ─────────────────────────────────────────────────

    match /usuarios/{uid} {

      // Lectura: propio usuario O Admin
      allow read: if request.auth != null
        && (request.auth.uid == uid || esAdmin());

      // Creación: auto-registro como comprador  |  Admin creando vendedor  |  seed del Admin
      allow create: if request.auth != null
        && (
          (request.auth.uid == uid && request.resource.data.rol == 'comprador')
          || (esAdmin() && request.resource.data.rol == 'vendedor')
          || (request.auth.uid == uid && request.resource.data.rol == 'admin')
        )
        && request.resource.data.keys().hasAll(['uid', 'email', 'nombre', 'rol', 'fechaRegistro']);

      // Actualización: propio usuario, con rol/email/fechaRegistro inmutables
      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.rol == resource.data.rol
        && request.resource.data.email == resource.data.email
        && request.resource.data.fechaRegistro == resource.data.fechaRegistro;

      // Eliminación: solo Admin, y no puede eliminarse a sí mismo
      allow delete: if request.auth != null
        && esAdmin()
        && request.auth.uid != uid;
    }

    // ─── Colección: tiendas ──────────────────────────────────────────────────

    match /tiendas/{tiendaId} {

      // Lectura: Admin O UsuarioVendedor propietario O Comprador (tiendas activas)
      allow read: if request.auth != null
        && (
          esAdmin()
          || resource.data.uidVendedor == request.auth.uid
          || (esComprador() && resource.data.activo == true)
        );

      // Creación: solo Admin
      allow create: if request.auth != null
        && esAdmin()
        && request.resource.data.keys().hasAll(['uidVendedor', 'nombreTienda', 'activo', 'fechaCreacion']);

      // Actualización: Admin puede editar todo;
      // Vendedor propietario puede editar nombreTienda/descripcion/foto (no uidVendedor ni fechaCreacion)
      allow update: if request.auth != null
        && (
          esAdmin()
          || (
            resource.data.uidVendedor == request.auth.uid
            && request.resource.data.uidVendedor == resource.data.uidVendedor
            && request.resource.data.fechaCreacion == resource.data.fechaCreacion
          )
        );

      // Eliminación: solo Admin
      allow delete: if request.auth != null && esAdmin();
    }

    // ─── Colección: productos ─────────────────────────────────────────────────

    match /productos/{productoId} {

      // Lectura: cualquier usuario autenticado (compradores necesitan ver el catálogo)
      allow read: if request.auth != null;

      // Creación: Vendedor propietario de la tienda
      allow create: if request.auth != null
        && esVendedor()
        && request.resource.data.uidTienda == request.auth.uid
        && request.resource.data.keys().hasAll(['uid', 'uidTienda', 'nombre', 'precio', 'disponible', 'fechaCreacion']);

      // Actualización: Vendedor propietario o Admin (uidTienda inmutable)
      allow update: if request.auth != null
        && (
          esAdmin()
          || (esVendedor() && resource.data.uidTienda == request.auth.uid)
        )
        && request.resource.data.uidTienda == resource.data.uidTienda;

      // Eliminación: Vendedor propietario o Admin
      allow delete: if request.auth != null
        && (esAdmin() || (esVendedor() && resource.data.uidTienda == request.auth.uid));
    }

    // ─── Colección: pedidos ───────────────────────────────────────────────────

    match /pedidos/{pedidoId} {

      // Lectura: comprador propietario O vendedor de la tienda O Admin
      allow read: if request.auth != null
        && (
          resource.data.uidComprador == request.auth.uid
          || resource.data.uidVendedor == request.auth.uid
          || esAdmin()
        );

      // Creación: solo el comprador, para sí mismo
      allow create: if request.auth != null
        && esComprador()
        && request.resource.data.uidComprador == request.auth.uid
        && request.resource.data.keys().hasAll(['uidComprador', 'uidVendedor', 'items', 'total', 'estado', 'fechaCreacion']);

      // Actualización: vendedor puede actualizar estado; Admin puede todo
      allow update: if request.auth != null
        && (
          esAdmin()
          || (esVendedor() && resource.data.uidVendedor == request.auth.uid)
        );

      // Eliminación: solo Admin
      allow delete: if request.auth != null && esAdmin();
    }
  }
}
